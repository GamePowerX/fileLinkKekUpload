{
  "manifest_version": 2,
  "name": "FileLinkKekUpload",
  "description": "A simple extension to upload attachment files to KekUpload",
  "version": "1.0",
  "author": "CraftingDragon007",
  "browser_specific_settings": {
    "gecko": {
      "id": "fileLinkKekUpload@gamepowerx.com",
      "strict_min_version": "128.0"
    }
  },
  "background": {
    "scripts": ["main.js"]
  },
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png"
  },
  "cloud_file": {
    "name": "FileLinkKekUpload",
    "management_url": "management.html"
  },
  "permissions": [
    "storage",
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ]
}
