{
    "name": "file-link-kekupload",
    "version": "1.0",
    "description": "A simple extension to upload attachment files to KekUpload",
    "author": "CraftingDragon007",
    "license": "GPL-3.0",
    "keywords": [
        "file",
        "upload",
        "kekupload"
    ],
    "devDependencies": {
        "@rollup/plugin-commonjs": "^18.1.0",
        "@rollup/plugin-node-resolve": "^13.0.6",
        "@types/node": "^16.4.13",
        "rollup": "^2.56.3",
        "tslib": "^2.3.1",
        "typescript": "^4.4.3",
        "@types/firefox-webext-browser": "94.0.1",
        "web-ext": "^7.0.0",
        "thunderbird-web-ext-types": "1.0.0"
    },
    "scripts": {
		"prepublishOnly": "npm run compile",
		"compile": "npm run clean && tsc -p . && cp *.html dist && cp manifest.json dist",
		"watch": "tsc -w -p .",
		"clean": "rm -rf dist",
		"format": "prettier --ignore-path .gitignore --write --plugin-search-dir=. ."
	}
}